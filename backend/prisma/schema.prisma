  PLATFORM_OWNER
  SCHOOL_OWNER
  ADMIN
  TEACHER
  PARENT
  STUDENT
  STAFF
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum SlotType {
  FIXED
  PERIOD
}

enum WidgetPriority {
  LOW
  MEDIUM
  HIGH
}

enum SubjectCategory {
  PRIMARY
  MIDDLE
  SECONDARY
  SENIOR_SECONDARY
}

enum StreamType {
  GENERAL
  SCIENCE
  COMMERCE
  ARTS
}

enum SubjectType {
  CORE
  OPTIONAL
  LAB
  ACTIVITY
}
