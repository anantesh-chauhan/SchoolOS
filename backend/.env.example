# ============================================================
# SCHOOLOS BACKEND ENVIRONMENT CONFIGURATION
# ============================================================

# App
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# ============================================================
# DB CONNECTION MODE
# Allowed: pooler | direct | supabase
# ============================================================
DB_CONNECTION_MODE=pooler

# ============================================================
# METHOD 1: SESSION POOLER (RECOMMENDED)
# Supabase Dashboard -> Settings -> Database -> Connection pooling -> Session mode
# ============================================================
MASTER_DB_HOST=aws-0-your-region.pooler.supabase.com
MASTER_DB_PORT=6543
MASTER_DB_USER=postgres
MASTER_DB_PASSWORD=your_db_password
MASTER_DB_NAME=postgres

# ============================================================
# METHOD 2: DIRECT POSTGRESQL
# Supabase Dashboard -> Settings -> Database -> Direct connection
# ============================================================
# MASTER_DB_HOST=db.your-project-ref.supabase.co
# MASTER_DB_PORT=5432
# MASTER_DB_USER=postgres
# MASTER_DB_PASSWORD=your_db_password
# MASTER_DB_NAME=postgres

# ============================================================
# METHOD 3: SUPABASE API CLIENT (@supabase/supabase-js)
# ============================================================
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_anon_public_key


